{
  "name": "badwers-notify",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/badwers-notify.cjs",
  "module": "./dist/badwers-notify.js",
  "exports": {
    ".": {
      "import": "./dist/badwers-notify.js",
      "require": "./dist/badwers-notify.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && tsc --emitDeclarationOnly --outDir dist",
    "preview": "vite preview",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "happy-dom": "^20.10.2",
    "prettier": "^3.8.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
